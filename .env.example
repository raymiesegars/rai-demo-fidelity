# ─── LiveKit (all services) ───────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=your-secret-here

# ─── OpenAI (agent) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Cartesia TTS (agent) ─────────────────────────────────────────────────
CARTESIA_API_KEY=sk_car_...
CARTESIA_VOICE_ID=df89f42f-f285-4613-adbf-14eedcec4c9e

# ─── Session / room ─────────────────────────────────────────────────────────
LIVEKIT_ROOM=patient-demo

# ─── Cost estimator (web) ───────────────────────────────────────────────────
NEXT_PUBLIC_GPU_HOURLY_RATE=0.69

# ─── RunPod (optional automation) ───────────────────────────────────────────
RUNPOD_API_KEY=rpa_...
RUNPOD_POD_ID=your-pod-id

# ─── Avatar worker ──────────────────────────────────────────────────────────
PATIENT_LOOP_PATH=../../alan-loop.mp4
TARGET_FPS=25
# mock = loop video only | gpu = JoyVASA lip sync (requires RunPod GPU)
AVATAR_MODE=mock
HUGGINGFACE_TOKEN=hf_...
