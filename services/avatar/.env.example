# Copy to services/avatar/.env

# Active talking-head backend: flashhead | flashhead-pro | wav2lip | musetalk | ditto | …
# AVATAR_BACKEND=flashhead
# Pro needs Model_Pro + VAE_Wan: .\setup_flashhead_pro.ps1 then -Backend flashhead-pro


# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# TTS provider: auto | openai | edge | elevenlabs | cartesia
# auto = ElevenLabs → OpenAI → Edge (free) → Cartesia
# For local testing with no TTS bills, use: TTS_PROVIDER=edge
TTS_PROVIDER=auto

# OpenAI TTS (uses OPENAI_API_KEY above; cheap, not free)
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy

# Edge TTS — free Microsoft voices, no API key (best for free testing)
# EDGE_TTS_VOICE=en-US-JennyNeural

# ElevenLabs (production target)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# Cartesia (optional; skipped in auto if OpenAI/Edge work)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL=sonic-2

# Idle motion (Silence → soft drive into FlashHead; not played aloud)
# 0 = pure silence (old behavior). Raise if faces look too still; lower if lips twitch.
IDLE_AUDIO_AMP=0.045
# MOTION_SEED=42
# IDLE_BREATH_HZ=0.27
# IDLE_NOD_HZ=0.95
# IDLE_BLINK_EVERY_S=3.6

# FlashHead Pro smoothness (defaults apply when AVATAR_BACKEND=flashhead-pro)
# FLASHHEAD_SMOOTH=1          # hold full reply, then play continuously (avoids mid-utterance freezes)
# FLASHHEAD_IDLE_GEN=0        # 0=static/hold while idle (Pro default). 1=generative idle (~5s freezes)
# FLASHHEAD_SAMPLE_STEPS=2    # 2 is faster; 4 is default quality (Lite)
# FLASHHEAD_JPEG_QUALITY=72

# Wav2Lip (after setup_wav2lip.ps1)
# WAV2LIP_ROOT=vendor/Wav2Lip
# WAV2LIP_CHECKPOINT=models/wav2lip_gan.pth

# Ditto (after setup_ditto.ps1)
# DITTO_PYTHON=.venv_ditto/Scripts/python.exe
# DITTO_DATA_ROOT=models/ditto/ditto_pytorch
# DITTO_CFG=models/ditto/ditto_cfg/v0.4_hubert_cfg_pytorch.pkl
# Paper realtime path uses 10; quality ≈ 50. Default 10 for local bench latency.
# DITTO_SAMPLING_TIMESTEPS=10

# MuseTalk (after setup_musetalk.ps1)
# MUSETALK_PYTHON=.venv_musetalk/Scripts/python.exe
# MUSETALK_ROOT=vendor/MuseTalk

# SadTalker (after setup_sadtalker.ps1)
# SADTALKER_PYTHON=.venv_sadtalker/Scripts/python.exe
# SADTALKER_ROOT=vendor/SadTalker
# SADTALKER_SIZE=256
# SADTALKER_PREPROCESS=full
# SADTALKER_STILL=1
# SADTALKER_BATCH_SIZE=2
# Optional face enhancer (slow): SADTALKER_ENHANCER=gfpgan

# Sonic (after setup_sonic.ps1) — CC BY-NC-SA non-commercial
# SONIC_PYTHON=.venv_sonic/Scripts/python.exe
# SONIC_ROOT=vendor/Sonic
# SONIC_MIN_RES=512
# SONIC_STEPS=10
# SONIC_DYNAMIC_SCALE=1.0
# SONIC_EXPAND_RATIO=0.5
# SONIC_RIFE=1
# For max fidelity scoring (slow): SONIC_STEPS=25
# Optional: SONIC_AUDIO_GUIDANCE=8.0

# LivePortrait / FasterLivePortrait + JoyVASA (after setup_liveportrait.ps1)
# LIVEPORTRAIT_PYTHON=.venv_liveportrait/Scripts/python.exe
# FLP_ROOT=vendor/FasterLivePortrait
# FLP_CFG=configs/onnx_infer.yaml
# FLP_ANIMATION_REGION=exp
# FLP_CFG_SCALE=1.2

# LiveTalk (after setup_livetalk.ps1) — Linux-leaning; Windows SDPA
# LIVETALK_PYTHON=.venv_livetalk/Scripts/python.exe
# LIVETALK_ROOT=vendor/LiveTalk
# LIVETALK_MAX_DURATION=8

# EchoMimicV3-Flash (after setup_echomimic.ps1)
# ECHOMIMIC_PYTHON=.venv_echomimic/Scripts/python.exe
# ECHOMIMIC_ROOT=vendor/echomimic_v3
# ECHOMIMIC_FLASH_DIR=vendor/echomimic_v3/flash
# ECHOMIMIC_STEPS=8
# ECHOMIMIC_SIZE=512
