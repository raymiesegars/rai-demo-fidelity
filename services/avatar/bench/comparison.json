{
  "categories": [
    {
      "id": "modality",
      "label": "Image animation vs video generation",
      "description": "image_animation = drive/edit a still via lipsync, warp, or 3DMM paste (source pixels largely preserved). video_generation = synthesize new frame pixels with a generative model (diffusion/flow), usually still image-conditioned \u2014 not text-to-video from scratch. Sonic is the latter (SVD img2vid).",
      "automated": false,
      "score_scale": "categorical"
    },
    {
      "id": "fidelity",
      "label": "Visual fidelity / natural vs uncanny",
      "description": "Manual score after watching the same clip set. Identity, skin, teeth, blinks, head motion, composite seams, and uncanny valley feel.",
      "automated": false,
      "score_scale": "1-10"
    },
    {
      "id": "concurrency",
      "label": "Concurrency / scalability",
      "description": "Effective concurrent sessions per GPU = 0.85/busy_ratio (fractional), capped by VRAM. Values below 1 mean the model is slower than realtime.",
      "automated": true,
      "score_scale": "sessions_per_gpu"
    },
    {
      "id": "latency",
      "label": "Latency & conversation speed",
      "description": "Time to first spoken frame, chunk gen time, realtime factor. Isolated from LiveKit/LLM where possible.",
      "automated": true,
      "score_scale": "ms"
    },
    {
      "id": "hosting",
      "label": "Hosting & server flexibility",
      "description": "Curated ops score (not UI-editable): self-host, Windows, deps fragility, license, day-2 restart pain. High = drop-in; low = heavy/fragile/restricted.",
      "automated": false,
      "score_scale": "1-10"
    },
    {
      "id": "cost",
      "label": "Cost",
      "description": "GPU $/session-hour = $0.44 \u00f7 effective sessions/GPU. Effective sessions = 0.85/busy_ratio (fractional; <1 if slower than realtime), also capped by VRAM. Not floored to 1.",
      "automated": true,
      "score_scale": "usd_per_session_hour"
    }
  ],
