LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=your-secret-here

LIVEKIT_ROOM=patient-demo
PATIENT_LOOP_PATH=assets/alan-loop.mp4
TARGET_FPS=25
# mock = idle loop | wav2lip = audio-reactive mouth + optional Wav2Lip batch
AVATAR_MODE=wav2lip
# Real-time mouth pulse on current pose (warp) | idle = loop only, no mouth pulse
MOUTH_DRIVE=warp
# Set to 1 for delayed blurry Wav2Lip replay (not recommended for live demo)
WAV2LIP_PLAYBACK=0
WAV2LIP_ROOT=/workspace/Wav2Lip
WAV2LIP_CHECKPOINT=/workspace/Wav2Lip/checkpoints/wav2lip_gan.pth

HUGGINGFACE_TOKEN=hf_...
