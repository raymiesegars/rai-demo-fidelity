LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=your-secret-here

LIVEKIT_ROOM=patient-demo
PATIENT_LOOP_PATH=assets/alan-loop.mp4
TARGET_FPS=25
# mock = idle loop | wav2lip = lip composite + Wav2Lip on anchor still
AVATAR_MODE=wav2lip
# composite = Wav2Lip lip patches on idle loop | idle = loop only while speaking
MOUTH_DRIVE=composite
# Smaller chunks = lip motion starts sooner (Wav2Lip runs ~0.5–2s per chunk on 4090)
LIP_SYNC_CHUNK_SEC=1.0
WAV2LIP_PLAYBACK=0
WAV2LIP_ROOT=/workspace/Wav2Lip
WAV2LIP_CHECKPOINT=/workspace/Wav2Lip/checkpoints/wav2lip_gan.pth

HUGGINGFACE_TOKEN=hf_...
